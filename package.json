{
  "name": "astro-book-bridge",
  "version": "0.1.0",
  "packageManager": "pnpm@11.12.0",
  "description": "Build a typed, locally enriched Astro book catalog from Goodreads RSS, Open Library and Google Books.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "examples/demo/src",
    "examples/demo/astro.config.mjs",
    "examples/demo/package.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "dev:demo": "pnpm --dir examples/demo dev",
    "build:demo": "pnpm --dir examples/demo build"
  },
  "keywords": [
    "astro",
    "goodreads",
    "open-library",
    "google-books",
    "rss",
    "books"
  ],
  "license": "MIT",
  "peerDependencies": {
    "astro": ">=4.0.0"
  },
  "dependencies": {
    "fast-xml-parser": "^5.2.5",
    "yaml": "^2.9.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@changesets/cli": "^2.31.1",
    "@types/node": "^26.1.1",
    "astro": "^7.1.3",
    "typescript": "^5.8.3",
    "vitest": "^4.1.10"
  }
}
